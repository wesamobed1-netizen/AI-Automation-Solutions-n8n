      "parameters": {
        "chatId": "1351398697",
        "text": "=🔔 *تقرير محادثة جديد*\n\n👤 *الزبون:* `{{ $('WhatsApp Trigger').item.json.messages[0].from }}`\n💬 *الطلب:* {{ $('Edit Fields').item.json.messages[0].text.body }} \n{{ $('Edit Fields').item.json.content.parts[0].text }}\n🤖 *الرد:* {{ $json.output }}",
